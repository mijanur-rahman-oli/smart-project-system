# .env.local

# ================================
# Application Configuration
# ================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
APP_NAME=ProjectFlow

# ================================
# Database Configuration (REQUIRED)
# ================================
# For local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/projectflow"

# For Neon PostgreSQL (alternative)
# DATABASE_URL="postgresql://username:password@ep-something.aws.neon.tech/projectflow?sslmode=require"

# For Supabase PostgreSQL (alternative)
# DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ================================
# Authentication (REQUIRED)
# ================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key-at-least-32-characters"
SESSION_TIMEOUT_MINUTES=30

# ================================
# Email Configuration (Optional - for notifications)
# ================================
# Gmail SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@projectflow.com"

# Resend (Alternative)
# RESEND_API_KEY="re_your_api_key"

# ================================
# File Storage (Optional - for attachments)
# ================================
# Vercel Blob (easiest for Vercel deployment)
BLOB_READ_WRITE_TOKEN="vercel-blob-token"

# AWS S3 (Alternative)
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"
# S3_BUCKET_NAME="projectflow-uploads"
# S3_REGION="us-east-1"

# UploadThing (Alternative)
# UPLOADTHING_SECRET="sk_live_your_secret"
# UPLOADTHING_APP_ID="your-app-id"

# ================================
# Redis Cache (Optional - for performance)
# ================================
# Local Redis
REDIS_URL="redis://localhost:6379"

# Upstash Redis (free tier available)
# UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# ================================
# WebSocket Configuration
# ================================
SOCKET_PATH="/api/socket"
SOCKET_CORS_ORIGIN="http://localhost:3000"

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# Security
# ================================
BCRYPT_ROUNDS=12
CSRF_SECRET="your-csrf-secret"
CORS_ORIGIN="http://localhost:3000"
SECURITY_HEADERS_ENABLED=true

# ================================
# Logging & Monitoring (Optional)
# ================================
LOG_LEVEL="info"

# Sentry (Optional)
# SENTRY_DSN="https://your-sentry-dsn"
# SENTRY_AUTH_TOKEN="your-sentry-token"

# ================================
# Analytics (Optional)
# ================================
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxxx"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ================================
# Feature Flags
# ================================
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_FILE_UPLOADS=false
ENABLE_REAL_TIME_UPDATES=true
ENABLE_EXPORT_FEATURE=true

# ================================
# File Upload Limits
# ================================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,image/webp,application/pdf,application/msword"

# ================================
# Cron Jobs (Vercel)
# ================================
CRON_SECRET="your-cron-secret"
CRON_CLEANUP_LOGS_ENABLED=true
CRON_CLEANUP_LOGS_SCHEDULE="0 0 * * 0"

# ================================
# Prisma Configuration
# ================================
PRISMA_LOG_LEVEL="info"
PRISMA_QUERY_LOGGING=false

# ================================
# Development Only
# ================================
NEXT_PUBLIC_DEV_MODE=true
DEBUG_MODE=true